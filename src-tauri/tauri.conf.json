{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferx",
  "version": "0.2.4",
  "identifier": "com.ferx.dev",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Ferx",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#ffffff"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "https://github.com",
          "https://*.githubusercontent.com",
          "https://objects.githubusercontent.com"
        ],
        "img-src": [
          "'self'",
          "data:",
          "blob:",
          "asset:",
          "http://asset.localhost",
          "https://www.google.com",
          "https://*.google.com",
          "https://*.gstatic.com"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "font-src": [
          "'self'",
          "data:"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2QUNCNTc4MzdFNzk4QjkKUldTNW1PYzNlTFdzRnF4YUlTelFuaStzQzljNWNzT1MyYW0vT0N0bHczcTI3dVFjeHk3bG9TT20K",
      "endpoints": [
        "https://github.com/adiwidia-dev/ferx/releases/latest/download/latest.json"
      ]
    }
  }
}
